# Copy to .env and fill in. docker-compose reads these for the backend service.
# NEVER commit the real .env.

# --- Secrets (required in any real environment) ---
JWT_SECRET=change-me-to-a-long-random-string
# 32-byte key as hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
BCRYPT_ROUNDS=12

# --- URLs ---
CLIENT_URL=http://localhost:3000

# --- CAPTCHA (optional; enables brute-force CAPTCHA when set) ---
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET=

# --- Email (optional; enables password-reset + security-alert emails) ---
EMAIL_USER=
EMAIL_PASSWORD=
ADMIN_ALERT_EMAIL=
